# Copiar a backend/.env — Supabase es la BD principal (sin Postgres en Docker)

# ── Base de datos (Supabase) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PROJECT_ID=

# Tipos de registro: ingeniero | abogado | empresa_inversora | empresa_local
# (ver POST /auth/register — profile_type)

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=cambia_esto_por_un_secreto_aleatorio_de_64_chars_recomendado
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_pon_tu_llave_aqui
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# ── Búsqueda web ───────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-pon_tu_llave_aqui

# ── ChromaDB (Cloud en producción / HTTP local en dev) ───────────────────────
# Chroma Cloud (Render): panel Connect → copiar tenant, database, API key
CHROMA_HOST=api.trychroma.com
CHROMA_PORT=443
CHROMA_SSL=true
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
# Sin CHROMA_API_KEY → usa servidor local:
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# ── Email OTP (Gmail: puerto 465 + SMTP_USE_SSL=true) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password_de_16_caracteres
EMAIL_FROM=Hub Chancay <tu_correo@gmail.com>

# ── Almacenamiento ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# ── Runtime ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SQL_ECHO=false
RUN_SEED_ON_START=true
CORS_ORIGINS=http://localhost:3000
